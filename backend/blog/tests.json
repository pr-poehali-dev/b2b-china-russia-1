{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "List published articles",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 200
    },
    {
      "name": "Get article without slug",
      "method": "GET",
      "path": "/?action=get",
      "expectedStatus": 400
    },
    {
      "name": "Create without admin token",
      "method": "POST",
      "path": "/?action=create",
      "body": {"title": "Test"},
      "expectedStatus": 403
    }
  ]
}