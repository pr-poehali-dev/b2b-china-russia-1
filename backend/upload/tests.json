{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Upload without token",
      "method": "POST",
      "path": "/?action=photo",
      "body": {"file": "aGVsbG8="},
      "expectedStatus": 401
    },
    {
      "name": "Video upload without token",
      "method": "POST",
      "path": "/?action=video_upload",
      "body": {"file": "aGVsbG8=", "content_type": "video/mp4"},
      "expectedStatus": 401
    },
    {
      "name": "Video presign without token",
      "method": "POST",
      "path": "/?action=video_presign",
      "body": {"content_type": "video/mp4", "size": 1000000},
      "expectedStatus": 401
    }
  ]
}