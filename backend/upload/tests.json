{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Upload without token",
      "method": "POST",
      "path": "/?action=photo",
      "body": {"file": "aGVsbG8="},
      "expectedStatus": 401
    },
    {
      "name": "Presign video without token",
      "method": "POST",
      "path": "/?action=presign_video",
      "body": {"filename": "test.mp4", "content_type": "video/mp4"},
      "expectedStatus": 401
    }
  ]
}